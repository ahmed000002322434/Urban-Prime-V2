{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/backend.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/backend?route=health"
    },
    {
      "source": "/webhooks/(.*)",
      "destination": "/api/backend?route=webhooks/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/backend?route=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
