PORT=5050
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
# Production example:
# CORS_ORIGIN=https://urbanprimebeta.vercel.app,https://yourdomain.com
PROFILE_ONBOARDING_V2=true
TRUST_PROXY=1
ENFORCE_AUTH_IN_PROD=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240
AUTH_RATE_LIMIT_MAX=60
# CORS_ALLOW_ALL=false
# CORS_ALLOW_SAME_HOST=true

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Optional shared secret for internal calls
# BACKEND_API_KEY=YOUR_INTERNAL_KEY

# Optional Firebase Admin auth bridge
# FIREBASE_ADMIN_CREDENTIALS={"type":"service_account",...}
# FIREBASE_ADMIN_CREDENTIALS_FILE=./service-account.json
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Optional uploads root (defaults to server/uploads)
# UPLOADS_DIR=./uploads

# Optional Cloudinary CDN adapter (when set, uploads prefer Cloudinary and fallback to local disk on error)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_UPLOAD_PRESET=
# CLOUDINARY_FOLDER=urbanprime
# CLOUDINARY_DELIVERY_BASE_URL=

# Pixe video pipeline (Mux)
# Set these on every server runtime target: local backend, Vercel server functions,
# Render/Railway/Fly/Node hosts, and any preview/staging backend.
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=
# MUX_WEBHOOK_SECRET=
# Optional dedicated Data API tokens; fall back to MUX_TOKEN_* when omitted
# MUX_DATA_TOKEN_ID=
# MUX_DATA_TOKEN_SECRET=

# Spotlight moderation controls
# SPOTLIGHT_BANNED_WORDS=word1,word2,word3
# SPOTLIGHT_BANNED_WORDS_ENFORCED=true

# Optional URL used in push notification click routing (example: https://app.urbanprime.com)
# APP_PUBLIC_URL=

# Push notification controls
# PUSH_NOTIFICATIONS_ENABLED=true
# WEB_PUSH_NOTIFICATION_ICON=/icons/favicon-192.png
# WEB_PUSH_NOTIFICATION_BADGE=/icons/favicon-64.png

# Email engagement and lifecycle notifications
# EMAIL_NOTIFICATIONS_ENABLED=true
# Optional test inbox. When set, every server email is delivered here instead of the real user.
# EMAIL_OVERRIDE_TO=
# EMAIL_UNREAD_MESSAGE_DEDUPE_MS=1800000
# EMAIL_EVENT_DEDUPE_MS=21600000
# EMAIL_REENGAGEMENT_AFTER_HOURS=48
# Optional AI copy assist. The AI returns plain text fields only; templates stay server-owned.
# EMAIL_AI_ENABLED=false
# EMAIL_AI_MODEL=gemini-1.5-flash
# GEMINI_API_KEY=
# GOOGLE_AI_API_KEY=

# WhatsApp Business Cloud API
# Create these in Meta Business Suite / WhatsApp Manager. Templates must be approved before production delivery.
# WHATSAPP_ENABLED=false
# WHATSAPP_DRY_RUN=false
# WHATSAPP_GRAPH_VERSION=v24.0
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
# WHATSAPP_DEFAULT_LOCALE=en_US
# WHATSAPP_TEMPLATE_AUTH_CODE=urbanprime_auth_code
# WHATSAPP_TEMPLATE_LOGIN_ALERT=urbanprime_login_alert
# WHATSAPP_TEMPLATE_OFFER_UPDATE=urbanprime_offer_update
# WHATSAPP_TEMPLATE_DISCOUNT_ALERT=urbanprime_discount_alert
# WHATSAPP_TEMPLATE_SELLER_UPDATE=urbanprime_seller_update
# WHATSAPP_TEMPLATE_FEED_ALERT=urbanprime_feed_alert
# WHATSAPP_TEMPLATE_VERIFICATION_UPDATE=urbanprime_verification_update
# WHATSAPP_TEMPLATE_RENTAL_REMINDER=urbanprime_rental_reminder

# Commerce rails (comma-separated; used by /commerce/providers and future gateway adapters)
# COMMERCE_PAYMENT_RAILS=stripe,paypal,razorpay,jazzcash,bank_transfer,local_bank
# COMMERCE_SHIPPING_RAILS=shippo,easypost,self_managed,local_courier
