PORT=5050
CORS_ORIGIN=http://localhost:3000
PROFILE_ONBOARDING_V2=true

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Optional shared secret for internal calls
# BACKEND_API_KEY=YOUR_INTERNAL_KEY

# Optional Firebase Admin auth bridge
# FIREBASE_ADMIN_CREDENTIALS={"type":"service_account",...}
# FIREBASE_ADMIN_CREDENTIALS_FILE=./service-account.json
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Optional uploads root (defaults to server/uploads)
# UPLOADS_DIR=./uploads
