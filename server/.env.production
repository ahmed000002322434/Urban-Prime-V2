# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# Backend API key for server-to-server authentication
# This should be a strong, randomly generated secret (min 32 chars)
# Generate with: openssl rand -hex 32
BACKEND_API_KEY=your_strong_production_secret_key_min_32_chars
ENFORCE_AUTH_IN_PROD=true

# ============================================================================
# FILE UPLOADS
# ============================================================================
# Directory for temporary uploads (in production, use cloud storage)
UPLOADS_DIR=./uploads

# ============================================================================
# CLOUDINARY (Optional - Recommended for image hosting in production)
# ============================================================================
# Using Cloudinary is recommended over local file storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
CLOUDINARY_FOLDER=urbanprime
CLOUDINARY_DELIVERY_BASE_URL=https://res.cloudinary.com/your_cloudinary_cloud_name

# ============================================================================
# RATE LIMITING (Production settings)
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240
AUTH_RATE_LIMIT_MAX=60

# ============================================================================
# FEATURE FLAGS (Production)
# ============================================================================
PROFILE_ONBOARDING_V2=true
CHAT_RELIABILITY_V2=true
BRAND_HUB_V3=true
PUSH_NOTIFICATIONS_ENABLED=true

# ============================================================================
# PUSH NOTIFICATIONS
# ============================================================================
WEB_PUSH_NOTIFICATION_ICON=/icons/favicon-192.png
WEB_PUSH_NOTIFICATION_BADGE=/icons/favicon-64.png
