# ============================================================================
# URBAN PRIME - BACKEND ENVIRONMENT (PRODUCTION)
# ============================================================================
# Created: April 17, 2026
# Location: server/ directory
# Upload to: Render, Railway, Heroku, AWS, etc.
# WARNING: Treat this file with extreme care. It contains secrets!

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Note: Cloud platforms (Render, Railway, Heroku) auto-set PORT
# Don't override it - let the platform set dynamic port
PORT=5050
HOST=0.0.0.0
NODE_ENV=production
APP_PUBLIC_URL=https://urbanprime-api.onrender.com

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# CRITICAL: Set this to your frontend's public URL
# Examples:
#   Vercel: https://urbanprime.vercel.app
#   Netlify: https://urbanprime.netlify.app
#   Custom domain: https://app.yourdomain.com
# For multiple domains, separate with commas
CORS_ORIGIN=https://urbanprime.vercel.app,https://www.yourdomain.com
CORS_ALLOW_ALL=false
CORS_ALLOW_SAME_HOST=true
TRUST_PROXY=true

