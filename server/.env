FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_ADMIN_CREDENTIALS=

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# If not using Firebase, provide a backend API key for authentication
# Generate: openssl rand -hex 32 (on Unix/Mac) or [System.Convert]::ToBase64String([System.Random]::new().GetBytes(32)) (PowerShell)
BACKEND_API_KEY=urbanprime_local_dev_backend_key_2026_32chars
ENFORCE_AUTH_IN_PROD=false

# ============================================================================
# FILE UPLOADS
# ============================================================================
UPLOADS_DIR=./uploads

# ============================================================================
# CLOUDINARY (Optional - For image hosting)
# ============================================================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
CLOUDINARY_FOLDER=urbanprime
CLOUDINARY_DELIVERY_BASE_URL=https://res.cloudinary.com/your_cloudinary_cloud_name

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240
AUTH_RATE_LIMIT_MAX=60

# ============================================================================
# FEATURE FLAGS
# ============================================================================
PROFILE_ONBOARDING_V2=true
CHAT_RELIABILITY_V2=true
BRAND_HUB_V3=true
PUSH_NOTIFICATIONS_ENABLED=true

# ============================================================================
# PUSH NOTIFICATIONS (Optional)
# ============================================================================
WEB_PUSH_NOTIFICATION_ICON=/icons/favicon-192.png
WEB_PUSH_NOTIFICATION_BADGE=/icons/favicon-64.png

# ============================================================================
# PORT RETRY (Advanced - for port conflicts)
# ============================================================================
PORT_RETRY_LIMIT=20
