{
    "name": "urban-prime-v1.0",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:frontdoor": "npm --prefix apps/frontdoor run build",
        "preview": "vite preview",
        "dev:client": "vite",
        "dev:frontdoor": "npm --prefix apps/frontdoor run dev -- --port 3001",
        "dev:server": "node server/src/index.js",
        "dev": "concurrently -k -n CLIENT,SERVER -c cyan,magenta \"npm:dev:client\" \"npm:dev:server\"",
        "dev:hybrid": "concurrently -k -n FRONTDOOR,CLIENT,SERVER -c yellow,cyan,magenta \"npm:dev:frontdoor\" \"npm:dev:client\" \"npm:dev:server\"",
        "setup:server": "npm --prefix server install",
        "setup:all": "npm install && npm --prefix server install",
        "start:frontdoor": "npm --prefix apps/frontdoor run start -- --port 3001"
    },
    "dependencies": {
        "@dotlottie/player-component": "^2.7.12",
        "@google/genai": "^1.34.0",
        "@supabase/supabase-js": "^2.49.1",
        "canvas-confetti": "^1.9.4",
        "d3": "^7.9.0",
        "firebase": "^12.7.0",
        "framer-motion": "^12.23.26",
        "gsap": "^3.15.0",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "react-helmet-async": "^2.0.5",
        "react-router-dom": "^7.13.0",
        "recharts": "2.12.7",
        "three": "0.132.2"
    },
    "devDependencies": {
        "@types/node": "^22.14.0",
        "@vitejs/plugin-react": "^5.0.0",
        "autoprefixer": "^10.4.21",
        "concurrently": "^8.2.2",
        "postcss": "^8.4.49",
        "tailwindcss": "^3.4.17",
        "typescript": "~5.8.2",
        "vite": "^6.2.0"
    }
}
