# Frontend runtime flags
VITE_DATA_MODE=supabase
VITE_ENABLE_FIRESTORE_FALLBACK=false
VITE_ENABLE_LOCAL_MOCK_FALLBACK=true
VITE_REQUIRE_BACKEND=false
VITE_PROFILE_ONBOARDING_V2=true

# Backend URL for client
VITE_BACKEND_URL=http://localhost:5050
# Optional: comma-separated fallback backends for runtime auto-discovery.
# Example:
# VITE_BACKEND_CANDIDATES=https://api.urbanprime.com,https://api-backup.urbanprime.com
VITE_BACKEND_CANDIDATES=
# Optional: map frontend host -> backend URL(s) for zero-downtime deployments.
# Format: host=primary|secondary;host2=https://another-backend.com
# Example:
# VITE_BACKEND_HOST_MAP=urbanprimebeta.vercel.app=https://urbanprime-api.vercel.app
VITE_BACKEND_HOST_MAP=
# Optional explicit backend for urbanprimebeta.vercel.app
VITE_URBANPRIMEBETA_BACKEND_URL=
# Optional: allow same-origin backend probing (default false)
VITE_BACKEND_ALLOW_SAME_ORIGIN=false
# Optional: cache GET responses in browser for offline reads (milliseconds)
VITE_BACKEND_READ_CACHE_TTL_MS=300000

# Supabase client
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=YOUR_PUBLISHABLE_KEY

# Optional direct browser write (usually keep false)
VITE_ENABLE_DIRECT_SUPABASE_MIRROR=false

# Optional backend API key forwarding
# VITE_BACKEND_API_KEY=YOUR_INTERNAL_KEY

# Firebase web push (required for service-worker push notifications)
# Generate from Firebase Console -> Cloud Messaging -> Web Push certificates
VITE_FIREBASE_VAPID_KEY=
