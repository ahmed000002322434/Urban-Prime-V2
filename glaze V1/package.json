    "build:web": "npm run build:desktop:web",
    "build": "npm run build:desktop",
    "release:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-windows-release.ps1",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "@tauri-apps/api": "^2.10.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "hash-wasm": "^4.12.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
