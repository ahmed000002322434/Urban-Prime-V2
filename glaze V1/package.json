{
  "name": "glaze-v1",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm --prefix site run dev",
    "dev:site": "npm --prefix site run dev",
    "dev:desktop:web": "vite",
    "dev:desktop": "tauri dev",
    "build:site": "npm --prefix site run build",
    "build:desktop:web": "tsc -b && vite build",
