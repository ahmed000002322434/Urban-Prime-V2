{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glaze",
  "version": "0.1.0",
  "identifier": "com.glaze.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:desktop:web",
    "beforeBuildCommand": "npm run build:desktop:web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Glaze",
        "width": 460,
        "height": 820,
        "minWidth": 104,
        "minHeight": 104,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "shadow": true,
        "skipTaskbar": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
